{
  "version": 2,
  "functions": {
    "api/predict.js": {
      "runtime": "nodejs18.x"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/web/$1"
    }
  ],
  "env": {
    "PYTHON_VERSION": "3.9"
  }
}
